<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Enhanced Comment Admin</label>
    <description>Full access to Enhanced Comment object, fields, Apex classes for managing comments (drafts, delete, purge).</description>

    <!-- Object Permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
        <object>Enhanced_Comment__c</object>
    </objectPermissions>

    <!-- Field Permissions: grant read/edit to all custom fields on Enhanced_Comment__c -->
    <fieldPermissions>
        <field>Enhanced_Comment__c.Comment_Number__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Body__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Plain_Body__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Channel__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Type__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Is_Public__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Is_Draft__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Thread_Count__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Enhanced_Comment__c.Email_Preview__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>EnhancedCommentController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>EnhancedCommentSelector</apexClass>
        <enabled>true</enabled>
    </classAccesses>

</PermissionSet>
